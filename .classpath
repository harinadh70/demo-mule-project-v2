<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="src" path="src/main/mule" including="**/*.xml" excluding="**/*.java"/>
	<classpathentry kind="src" path="src/main/resources" excluding="**/*.mule"/>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER"/>
	<classpathentry kind="lib" path="lib/mysql-connector-java-8.0.30.jar"/>
	<classpathentry kind="lib" path="lib/postgresql-42.7.3.jar"/>
	<classpathentry kind="lib" path="lib/mssql-jdbc-12.6.1.jre11.jar"/>
	<classpathentry kind="output" path="target/classes"/>
</classpath>
